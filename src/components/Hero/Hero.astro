---
import Prose from "../Prose/Prose.astro"
import LinkButton from "../LinkButton/LinkButton.astro"
import classes from "./Hero.module.scss"
import { heroContent } from "../../config/hero-content"
import { heroActions } from "../../config/hero-actions"
---
<section class={classes.Hero}>
    <Prose class={classes.Hero__content}>
        <h1>{heroContent.title}</h1>
        <p>{heroContent.description}</p>
    </Prose>
    <div class={classes.Hero__actions}>
        {heroActions.map((heroAction) => (
            <LinkButton 
                variant={heroAction.variant}
                href={heroAction.href}
            >{heroAction.label}</LinkButton>
        ))}
    </div>
</section>
