---
import { icon } from "@fortawesome/fontawesome-svg-core"
import NavbarLinks from "./NavbarLinks.astro"
import LinkButton from "../LinkButton/LinkButton.astro"
import classes from "./Navbar.module.scss"
import { site } from "../../config/site"
import { availableSocialIconset, SocialIconName, navbarSocialLinks } from "../../config/navbar-social-links"
import { navbarActions } from "../../config/navbar-actions"

const renderSocialIcon = (name: SocialIconName) =>
    icon(availableSocialIconset[name], {
        attributes: {
            focusable: "false",
            "aria-hidden": "true",
        }
    }).html.join("")
---

<nav class={classes.Navbar}>
    <div class={classes.Navbar__layout}>
        <a href={site.homeUrl} class={classes.Navbar__brand}>{site.name}</a>
        <div class={classes.Navbar__links}>
            <NavbarLinks />
        </div>
        <div class={classes.Navbar__actions}>
            {navbarSocialLinks.map((navbarSocialLink) => {
                return (
                    <LinkButton
                        variant="ghost"
                        href={navbarSocialLink.href}
                        title={navbarSocialLink.tooltip}
                        data-handle={navbarSocialLink.handle}
                        aria-label={navbarSocialLink.tooltip}
                    >
                        <Fragment set:html={renderSocialIcon(navbarSocialLink.icon)} />
                    </LinkButton>
                )
            })}
            {navbarActions.map((navbarAction) => {
                return (
                    <LinkButton 
                        href={navbarAction.href} 
                        variant={navbarAction.variant}
                    >{navbarAction.label}</LinkButton>
                )
            })}
        </div>
    </div>
</nav>
